# Optional: copy to `apps/tauri-pos/.env` (or export in CI) before `pnpm build` / `tauri build`.
# Variables are read when `beforeBuildCommand` runs the Vite production build.
# If omitted, the web bundle defaults the API to http://127.0.0.1:4000 when built for Tauri (see apps/web/src/lib/app-api.ts).
VITE_API_ORIGIN=http://127.0.0.1:4000

# Optional: set in the shell when launching the installed app (kiosk-style).
# POS_KIOSK=1
