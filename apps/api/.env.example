# Copy to `.env` for local development (`cp .env.example .env`).
#
# Default (development): bundled embedded PostgreSQL on 127.0.0.1:55432 — no Docker installer required.
# To use Docker Postgres on localhost:5432 instead, set POS_EMBEDDED_POSTGRES=false and keep DATABASE_URL below.
NODE_ENV=development
# LAN server mode (all interfaces). Use 127.0.0.1 for localhost-only.
LISTEN_HOST=0.0.0.0
PORT=4000
POS_EMBEDDED_POSTGRES=true
# Used when POS_EMBEDDED_POSTGRES=false (e.g. `pnpm run dev:api:stack` with Docker).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pos_dev?schema=public
API_BASE_PATH=/api/v1
# Comma-separated browser / Tauri origins. Leave unset to reflect the request Origin (local POS + desktop default).
# CORS_ORIGINS=https://app.example.com,http://localhost:5173
LOG_LEVEL=info
BCRYPT_ROUNDS=12
TRUST_PROXY=false

# Auth — use long random strings in production (32+ chars each).
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ISSUER=pos-api
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
# HMAC input for PIN before bcrypt (must match seed / mobile clients if they pre-hash — server-side only here).
PIN_PEPPER=change-me-pin-pepper-min-32-chars-long
AUTH_MAX_FAILED_LOGINS=8
AUTH_LOCKOUT_MINUTES=15
# Local dev / Tauri (`POS_DESKTOP_RUNTIME=1`): HTTP rate limits and account lockout are disabled automatically.
# Set true to always return refresh token in JSON (cookie still set when applicable).
# Also enabled automatically for POS desktop runtime and localhost/Tauri webview origins.
AUTH_REFRESH_TOKEN_IN_BODY=false
