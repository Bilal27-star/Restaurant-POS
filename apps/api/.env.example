# Copy to `.env` for local development (`cp .env.example .env`).
# Quick start (Docker): from repo root run `pnpm run dev:api:stack` — starts Postgres, applies migrations, runs the API on PORT.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pos_dev?schema=public
API_BASE_PATH=/api/v1
# Comma-separated browser / Tauri origins. Leave unset to reflect the request Origin (local POS + desktop default).
# CORS_ORIGINS=https://app.example.com,http://localhost:5173
LOG_LEVEL=info
BCRYPT_ROUNDS=12
TRUST_PROXY=false

# Auth — use long random strings in production (32+ chars each).
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ISSUER=pos-api
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
# HMAC input for PIN before bcrypt (must match seed / mobile clients if they pre-hash — server-side only here).
PIN_PEPPER=change-me-pin-pepper-min-32-chars-long
AUTH_MAX_FAILED_LOGINS=8
AUTH_LOCKOUT_MINUTES=15
# Set true to also return refresh token in JSON (desktop POS); cookie still recommended for web.
AUTH_REFRESH_TOKEN_IN_BODY=false
